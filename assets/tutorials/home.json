            "blockMode": "allowTarget",
            "nextStepId": "pulse_timeline"
        },
        {
            "id": "pulse_timeline",
            "title": "Pulse Timeline",
            "body": "Your life journey appears here.",
            "targetId": "timeline.intelligence_strip",
            "trigger": "manual",
            "blockMode": "allowTarget",
            "nextStepId": "pulse_habit_area"
        },
        {
            "id": "pulse_habit_area",
            "title": "Pulse Habit Area",
            "body": "Habits build momentum every day.",
            "targetId": "settings.habit_toggle",
            "trigger": "manual",
            "blockMode": "allowTarget",
            "nextStepId": "pulse_coach"
        },
        {
            "id": "pulse_coach",
            "title": "Pulse Coach",
            "body": "Your SI Coach is always available.",
            "targetId": "home.start_focus_button",
            "trigger": "manual",
            "blockMode": "allowTarget",
            "nextStepId": "finish"
