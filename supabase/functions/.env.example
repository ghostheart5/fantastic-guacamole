# Server-only environment for Supabase Edge Functions or any separate backend runtime.
# Do not commit real values. Do not copy these secrets into the Flutter root .env.

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<publishable-key>
SUPABASE_SECRET_KEY=<secret-key>
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json

# Legacy aliases that Supabase-hosted Edge Functions still inject automatically.
SUPABASE_ANON_KEY=<publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<secret-key>

# Existing function-specific secrets
ALLOWED_ORIGINS=https://chronospark.app,https://www.chronospark.app
ANTHROPIC_API_KEY=<anthropic-api-key>
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account"}
ANDROID_PACKAGE_NAME=com.ghostheart5.chronospark