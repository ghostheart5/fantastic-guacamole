# Client/runtime values for the Flutter app only.
# Do not put SUPABASE_SECRET_KEY here; keep server secrets in supabase/functions/.env.
CHRONOSPARK_SUPABASE_URL=https://<project-ref>.supabase.co
CHRONOSPARK_SUPABASE_ANON_KEY=<anon-key>
CHRONOSPARK_ENABLE_MOCK_LOGIN=false
CHRONOSPARK_OAUTH_REDIRECT_URL=chronospark://auth-callback
CHRONOSPARK_GITHUB_OAUTH_REDIRECT_URL=chronospark://auth-callback
CHRONOSPARK_RECEIPT_VERIFY_ENDPOINT=https://<your-domain>/monetization-verify
CHRONOSPARK_AI_PROXY_ENDPOINT=https://<your-domain>/ai-proxy
CHRONOSPARK_ACCOUNT_DELETE_ENDPOINT=https://<your-domain>/account-delete
CHRONOSPARK_ANDROID_SHA256_CERT=<release-cert-sha256>
CHRONOSPARK_IOS_TEAM_ID=<apple-team-id>
